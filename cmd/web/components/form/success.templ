package form

templ Success(msg string, closeLabel string) {
<div class="bg-green-50 border border-green-200 text-green-800 px-6 py-8 rounded-xl text-center space-y-6">
    <div class="text-5xl">✓</div>
    <h3 class="text-xl font-semibold">{ msg }</h3>
    <button @click="ui.modal.open = false"
            class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">
        { closeLabel }
    </button>
</div>
}