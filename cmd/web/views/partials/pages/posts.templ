package pages

import "comics-galore-web/internal/blog"
import "comics-galore-web/cmd/web/components/pagination"
import "comics-galore-web/cmd/web/components/card"

templ PostsPage(posts []blog.Post, paginationProps pagination.Props) {
<div class="p-6">
    <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        for _, c := range posts {
        @card.Card(&c, false)
        }
    </div>
    @pagination.Pagination(paginationProps)
</div>
}
