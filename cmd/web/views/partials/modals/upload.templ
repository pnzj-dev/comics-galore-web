    <form hx-post="/api/posts" hx-ext="json-enc">
        @form.FileUpload(form.FileUploadProps{
            Name:       "cover_key",
            Label:      "Cover Image",
            Accept:     "image/*",
            PresignUrl: "/api/upload/presign",
            UploadPath: "form.cover",
        })

        @form.FileUpload(form.FileUploadProps{
            Name:       "avatar_key",
            Label:      "Author Avatar",
            Accept:     "image/png,image/jpeg",
            PresignUrl: "/api/upload/presign",
            UploadPath: "form.author.avatar",
        })

        <button type="submit" class="btn-primary">Submit Post</button>
    </form>
} -->
}

